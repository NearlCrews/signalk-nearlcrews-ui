{
  "name": "signalk-nearlcrews-ui",
  "version": "0.1.0",
  "description": "Accessible, theme-aware React primitives for Signal K administration panels.",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "signalk",
    "react",
    "ui",
    "components",
    "accessibility",
    "marine",
    "module-federation",
    "design-system"
  ],
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.13.0 || ^24.0.0 || ^26.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "^11.16.0 || ^12.0.0",
      "onFail": "error"
    }
  },
  "packageManager": "npm@12.0.1",
  "peerDependencies": {
    "react": ">=19.2.0 <20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com",
    "url": "https://github.com/NearlCrews"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/NearlCrews/signalk-nearlcrews-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-nearlcrews-ui.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-nearlcrews-ui/issues"
  },
  "scripts": {
    "build": "node scripts/clean.mjs && tsc -p tsconfig.build.json",
    "clean": "node scripts/clean.mjs",
    "format": "biome check --write . && prettier --write \"**/*.{md,yml,yaml}\"",
    "format:check": "biome format . && prettier --check \"**/*.{md,yml,yaml}\"",
    "lint": "npm run lint:biome && npm run lint:eslint",
    "lint:biome": "biome check --error-on-warnings .",
    "lint:eslint": "eslint . --max-warnings 0",
    "knip": "knip",
    "type-check": "tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "audit:runtime": "npm audit --omit=dev --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest:browser": "npm run build && npm run test:federation:built",
    "test:browser": "playwright test",
    "pretest:browser:update": "npm run build && npm run test:federation:built",
    "test:browser:update": "playwright test --update-snapshots",
    "test:bundle": "npm run build && npm run test:bundle:built",
    "test:bundle:built": "node scripts/check-bundle-size.mjs",
    "test:federation": "npm run build && npm run test:federation:built",
    "test:federation:built": "webpack --config fixtures/federation/classic/webpack.config.cjs --json fixtures/federation/classic/dist/stats.json && webpack --config fixtures/federation/esm/webpack.config.cjs --json fixtures/federation/esm/dist/stats.json && node scripts/check-federation-build.mjs",
    "test:package": "npm run build && npm run test:package:built",
    "test:package:built": "publint && node scripts/check-package.mjs",
    "validate": "npm run format:check && npm run lint && npm run knip && npm run type-check && npm run test:coverage && npm run audit && npm run audit:runtime && npm run build && npm run test:package:built && npm run test:bundle:built && npm run test:federation:built",
    "release:check": "node scripts/check-release-approval.mjs && npm run validate && npm run test:browser",
    "prepublishOnly": "node scripts/check-release-approval.mjs && npm run test:browser",
    "prepack": "npm run validate"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.4",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
